@page "/CreateTodo"
@attribute [Authorize]
@using UIComponents
@using HttpClients.ClientInterfaces
@using Shared.DTOs
@inject ITodoService todoService
@inject NavigationManager navMgr

<div class="form-card wide surface">
    <h2>Create todo</h2>
    <div class="form-group field">
        <label>Title</label>
        <input type="text" @bind="todoTitle" />
    </div>
    <div class="form-group field">
        <label>Description</label>
        <textarea @bind="description"></textarea>
    </div>
    @if (!string.IsNullOrEmpty(msg))
    {
        <div class="message error">@msg</div>
    }
    <div class="button-row">
        <button @onclick="Create" class="acceptbtn">Create</button>
    </div>
</div>

<Modal ShowModal="showModal">
    <p>You have successfully added a new Todo item. You should be very proud of yourself!</p>
    <button @onclick="@Proceed">Wonderful</button>
</Modal>

@code {
    private string todoTitle = "";
    private string? description;
    private string msg = "";
    private bool showModal;

    private async Task Create()
    {
        msg = "";

        if (string.IsNullOrWhiteSpace(todoTitle))
        {
            msg = "Title cannot be empty!";
            return;
        }

        try
        {
            // The backend ignores ownerId for normal users and reads the real owner from the JWT.
            // We keep 1 only because the shared DTO still requires a positive owner id.
            TodoCreationDto dto = new(1, todoTitle, description);
            await todoService.CreateAsync(dto);
            showModal = true;
        }
        catch (Exception e)
        {
            Console.WriteLine(e);
            msg = e.Message;
        }
    }

    private void Proceed()
    {
        showModal = false;
        navMgr.NavigateTo("/ViewTodos");
    }
}
