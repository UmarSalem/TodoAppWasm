@page "/ViewTodos"
@attribute [Authorize]
@inject NavigationManager navMgr
@using HttpClients.ClientInterfaces
@using UIComponents
@using Shared.DTOs
@inject ITodoService todoService

<div class="page-header">
    <div>
        <h1 class="page-title">Todos</h1>
        <p class="page-description">View, filter, complete, edit, and delete the todos for the logged-in account.</p>
    </div>
    <a class="button" href="CreateTodo">New todo</a>
</div>

<div class="surface todo-toolbar">
    <button class="button secondary" @onclick="@(() => doShowFilters = !doShowFilters)">
        @(doShowFilters ? "Hide filters" : "Show filters")
    </button>
    <button @onclick="LoadTodos">Load todos</button>

    @if (doShowFilters)
    {
        <div class="filter-grid">
            <div class="field">
                <label>Completed status</label>
                <select @bind="completedStatusFilter">
                    <option value="all">All</option>
                    <option value="true">Completed</option>
                    <option value="false">Open</option>
                </select>
            </div>
            <div class="field">
                <label>Title contains</label>
                <input type="text" @bind="titleContainsFilter" />
            </div>
        </div>
    }
</div>

@if (todos == null)
{
}
else if (!todos.Any())
{
    <div class="empty-state">No todos to display.</div>
}
else
{
    <div class="surface table-surface">
        <table class="table">
            <thead>
                <tr>
                    <th>Todo ID</th>
                    <th>Owner ID</th>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Completed</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in todos)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.OwnerId</td>
                        <td>@item.Title</td>
                        <td>@item.Description</td>
                        <td>
                            <FancyCheckBox IsCompleted="@item.IsCompleted" OnChange="@((status) => CompleteTodo(item, status))" />
                        </td>
                        <td class="table-actions">
                            <button class="button secondary" @onclick="@(() => navMgr.NavigateTo($"/EditTodo/{item.Id}"))">Edit</button>
                            <button class="danger-button" @onclick="@(() => RemoveTodo(item.Id))">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
@if (!string.IsNullOrEmpty(msg))
{
    <div class="message error">@msg</div>
}

@code {
    private IEnumerable<TodoReadDto>? todos;
    private string msg = "";
    private bool doShowFilters = false;

    private string? completedStatusFilter;
    private string? titleContainsFilter;

    private async Task LoadTodos()
    {
        try
        {
            bool? completedFilterValue = null;
            if (!string.IsNullOrEmpty(completedStatusFilter) && !completedStatusFilter.Equals("all"))
            {
                completedFilterValue = bool.Parse(completedStatusFilter);
            }

            // The backend reads the logged-in user from the JWT, so normal users do not
            // need username/userId filters here.
            todos = await todoService.GetAsync(null, null, completedFilterValue, titleContainsFilter);
        }
        catch (Exception e)
        {
            Console.WriteLine(e);
            msg = e.Message;
        }
    }

    private async Task CompleteTodo(TodoReadDto item, bool status)
    {
        TodoUpdateDto dto = new(item.Id)
            { IsCompleted = status };
        try
        {
            await todoService.UpdateAsync(dto);
        }
        catch(Exception e)
        {
            Console.WriteLine(e);
            msg = e.Message;
        }
    }

    private async Task RemoveTodo(int todoId)
    {
        msg = "";
        try
        {
            await todoService.DeleteAsync(todoId);

            var list = new List<TodoReadDto>(todos!);
            list.RemoveAll(todo => todo.Id == todoId);
            todos = list.AsEnumerable();
        }
        catch (Exception e)
        {
            Console.WriteLine(e);
            msg = e.Message;
        }
    }
}
