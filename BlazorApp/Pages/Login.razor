@page "/Login"
@using Shared.DTOs
@inject IAuthService AuthService
@inject NavigationManager NavMgr

<div class="form-card surface">
    <h2>Login</h2>

    <div class="form-group field">
        <label>User name</label>
        <input type="text" @bind="username" @bind:event="oninput" />
    </div>

    <div class="form-group field">
        <label>Password</label>
        <input type="password" @bind="password" @bind:event="oninput" />
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="message error">@message</div>
    }

    <div class="button-row">
        <button class="acceptbtn"
                @onclick="LoginAsync"
                disabled="@IsLoginDisabled">
            @(isBusy ? "Logging in..." : "Login")
        </button>
    </div>
</div>

@code {
    private string username = "";
    private string password = "";
    private string message = "";
    private bool isBusy;

    private bool IsLoginDisabled =>
        isBusy || string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password);

    private async Task LoginAsync()
    {
        message = "";
        isBusy = true;

        try
        {
            await AuthService.LoginAsync(new UserLoginDto(username, password));
            NavMgr.NavigateTo("/ViewTodos");
        }
        catch (Exception e)
        {
            message = e.Message;
        }
        finally
        {
            isBusy = false;
        }
    }
}
