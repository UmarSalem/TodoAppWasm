@page "/ViewUsers"
@using Shared.DTOs
@using HttpClients.ClientInterfaces
@inject IUserService userService

<div class="page-header">
    <div>
        <h1 class="page-title">Users</h1>
        <p class="page-description">Review the accounts created in the system.</p>
    </div>
    <a class="button" href="CreateUser">New user</a>
</div>

@if (!string.IsNullOrEmpty(msg))
{
    <div class="message error">@msg</div>
}

@if (users == null)
{
    <div class="empty-state">Loading users...</div>
}
else if (!users.Any())
{
    <div class="empty-state">No users to be found.</div>
}
else
{
    <div class="surface table-surface">
        <table class="table">
            <thead>
                <tr>
                    <th>User ID</th>
                    <th>User name</th>
                    <th>Role</th>
                </tr>
            </thead>
            <tbody>
                @foreach (UserReadDto user in users)
                {
                    <tr>
                        <td>@user.Id</td>
                        <td>@user.UserName</td>
                        <td>@user.Role</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private IEnumerable<UserReadDto>? users;
    private string msg = "";

    protected override async Task OnInitializedAsync()
    {
        msg = "";
        try
        {
            users = await userService.AsyncGetUsers();
        }
        catch (Exception e)
        {
            Console.WriteLine(e);
            msg = e.Message;
        }
    }
}
